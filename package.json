{
  "name": "perf-analyzer",
  "version": "1.0.0",
  "description": "Web app to benchmark a PC and highlight EDR/VPN impact (CPU, Disk, RAM, Network)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:manual": "vite build && wrangler deploy",
    "cf:login": "wrangler login",
    "db:migrate": "wrangler d1 execute perf-analyzer-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute perf-analyzer-db --local --file=./schema.sql",
    "dev:full": "vite build && wrangler dev"
  },
  "devDependencies": {
    "vite": "^5.4.10",
    "wrangler": "^4.105.0"
  }
}
